  create view "supply_integration"."main"."stg_xdc_print_prices__dbt_tmp" as (
    
-- Global print price matrix: technique × color_count × area_range.
-- 9 fixed quantity breakpoints stored as named columns; unpivoted in the intermediate layer.
-- area_min / area_max are in cm²; converted to mm² (×100) in int_xdc_print_prices.
with source as (
    select * from read_parquet('s3://supply-integration/xdc/raw/print_option_price/*/print_option_price.parquet')
)

select
    print_technique,
    try_cast(print_color_quantity as integer) as print_color_quantity,
    try_cast(has_full_color       as boolean) as has_full_color,
    try_cast(area_min             as decimal(10, 4)) as area_min_cm2,
    try_cast(area_max             as decimal(10, 4)) as area_max_cm2,
    try_cast(product_quantity_min as integer) as product_quantity_min,
    try_cast(price_setup          as decimal(10, 2)) as price_setup,
    try_cast(price_quantity_1     as decimal(10, 4)) as price_quantity_1,
    try_cast(price_quantity_50    as decimal(10, 4)) as price_quantity_50,
    try_cast(price_quantity_100   as decimal(10, 4)) as price_quantity_100,
    try_cast(price_quantity_250   as decimal(10, 4)) as price_quantity_250,
    try_cast(price_quantity_500   as decimal(10, 4)) as price_quantity_500,
    try_cast(price_quantity_1000  as decimal(10, 4)) as price_quantity_1000,
    try_cast(price_quantity_2500  as decimal(10, 4)) as price_quantity_2500,
    try_cast(price_quantity_5000  as decimal(10, 4)) as price_quantity_5000,
    try_cast(price_quantity_10000 as decimal(10, 4)) as price_quantity_10000

from source
where print_technique is not null
  );

