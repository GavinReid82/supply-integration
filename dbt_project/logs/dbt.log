  create view "supply_integration"."main"."stg_xdc_prices__dbt_tmp" as (
    
-- Variant-level price tiers. XDC provides up to 5 custom quantity breaks per variant.
-- Unpivots wide format (quantity_1..5, price_quantity_1..5) into one row per variant/tier.
with source as (
    select * from read_parquet('s3://supply-integration/xdc/raw/product_price/*/product_price.parquet')
),

unpivoted as (
    select variant_id, 1 as tier,
           try_cast(quantity_1       as integer)        as quantity_min,
           try_cast(price_quantity_1 as decimal(10, 4)) as unit_price
    from source where quantity_1 is not null

    union all
    select variant_id, 2,
           try_cast(quantity_2 as integer), try_cast(price_quantity_2 as decimal(10, 4))
    from source where quantity_2 is not null

    union all
    select variant_id, 3,
           try_cast(quantity_3 as integer), try_cast(price_quantity_3 as decimal(10, 4))
    from source where quantity_3 is not null

    union all
    select variant_id, 4,
           try_cast(quantity_4 as integer), try_cast(price_quantity_4 as decimal(10, 4))
    from source where quantity_4 is not null

    union all
    select variant_id, 5,
           try_cast(quantity_5 as integer), try_cast(price_quantity_5 as decimal(10, 4))
    from source where quantity_5 is not null
)

select * from unpivoted
where unit_price is not null
  and quantity_min is not null
  );

