  create view "supply_integration"."main"."stg_xdc_variants__dbt_tmp" as (
    
-- One row per variant. Product and variant data are in a single XDC feed.
-- Column names reflect the Excel headers after lowercase + space→underscore normalisation.
-- Dimensions are in cm in the raw feed; converted to mm here.
-- Weight is in grams in the raw feed; converted to kg here.
with source as (
    select * from read_parquet('s3://supply-integration/xdc/raw/product/*/product.parquet')
)

select
    product_id,
    variant_id,
    product_name,
    description,
    brand,
    category,
    subcategory,
    material,
    color,
    hex_color,
    size,
    try_cast(length   as decimal(8, 2)) * 10  as length_mm,
    try_cast(width    as decimal(8, 2)) * 10  as width_mm,
    try_cast(height   as decimal(8, 2)) * 10  as height_mm,
    try_cast(diameter as decimal(8, 2)) * 10  as diameter_mm,
    try_cast(weight   as decimal(10, 3)) / 1000 as weight_kg,
    hscode,
    try_cast(quantity_per_box as integer)     as quantity_per_box,
    image_product_url,
    image_variant_url,
    _product_life_cycle,
    _product_type

from source
where product_id is not null
  and variant_id is not null
  );

