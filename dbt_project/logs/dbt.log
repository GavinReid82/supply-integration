  create view "catalog_data_platform"."main"."int_mko_variants__dbt_tmp" as (
    with variants as (
    select * from "catalog_data_platform"."main"."stg_mko_variants"
),

availability as (
    select product_ref, bool_or(in_stock_now) as is_available
    from "catalog_data_platform"."main"."stg_mko_stock"
    group by product_ref
),

hscodes as (
    select variant_id, hs_code from "catalog_data_platform"."main"."mko_product__hscode"
)

select
    'mko'                           as supplier,
    v.product_ref,
    v.matnr                         as variant_id,
    v.sku_code,
    v.colour_code,
    v.colour_name,
    v.size,
    v.image_url_500px               as image_url,
    coalesce(a.is_available, false) as is_available,
    null                            as attribute_json,
    h.hs_code

from variants v
left join availability a on v.product_ref = a.product_ref
left join hscodes      h on v.matnr = h.variant_id
qualify row_number() over (partition by v.product_ref, v.matnr order by 1) = 1
  );

