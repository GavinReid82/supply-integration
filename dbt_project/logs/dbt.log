  create view "supply_integration"."main"."stg_mko_stock__dbt_tmp" as (
    with source as (
    select * from read_parquet('s3://supply-integration/mko/raw/stock/*/stock.parquet')
)

select
    ref                                                 as product_ref,
    warehouse,
    try_cast(stock as integer)                          as stock_qty,
    case
        when lower(available) = 'immediately' then current_date
        else try_cast(available as date)
    end                                                 as available_date,
    available = 'immediately'                           as in_stock_now

from source
  );

