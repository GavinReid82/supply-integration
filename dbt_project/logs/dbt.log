    -- minimum order
    try_cast(order_min_product as integer)      as min_order_qty,

    -- categories (up to 3 levels — extend if needed)
    category_ref_1,
    category_name_1,
    category_ref_2,
    category_name_2,
    category_ref_3,
    category_name_3,

    imagemain,

    -- links
    link360,
    linkvideo

from source
qualify row_number() over (partition by ref order by ref) = 1
  );

